generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Site {
  id           String   @id @default(cuid())
  name         String
  address      String?
  contactName  String?
  contactEmail String?
  contactPhone String?
  notes        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  orders       Order[]
  bulkOrders   BulkOrder[]
}

model MenuCategory {
  id        String     @id @default(cuid())
  name      String
  sortOrder Int        @default(0)
  menuItems MenuItem[]
}

model MenuItem {
  id            String             @id @default(cuid())
  name          String
  description   String?
  unitLabel     String             @default("each")
  bulkQty       Int                @default(1)
  price         Decimal            @default(0) @db.Decimal(10, 2)
  isActive      Boolean            @default(true)
  category      MenuCategory       @relation(fields: [categoryId], references: [id])
  categoryId    String
  createdAt     DateTime           @default(now())
  orderItems    OrderItem[]
  menuTemplateItems MenuTemplateItem[]
  bulkOrderItems    BulkOrderItem[]
}

// A Menu now has a defined template of items + default quantities
model Menu {
  id          String         @id @default(cuid())
  name        String
  description String?
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  orders      Order[]
  templateItems MenuTemplateItem[]
}

// Default items/quantities that come with a menu
model MenuTemplateItem {
  id           String   @id @default(cuid())
  menu         Menu     @relation(fields: [menuId], references: [id], onDelete: Cascade)
  menuId       String
  menuItem     MenuItem @relation(fields: [menuItemId], references: [id])
  menuItemId   String
  defaultQty   Int      @default(1)

  @@unique([menuId, menuItemId])
}

model Order {
  id           String      @id @default(cuid())
  site         Site        @relation(fields: [siteId], references: [id])
  siteId       String
  menu         Menu        @relation(fields: [menuId], references: [id])
  menuId       String
  deliveryDate DateTime
  status       OrderStatus @default(PENDING)
  notes        String?
  headCount    Int?        // number of people — used for scaling template quantities
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  items        OrderItem[]
}

model OrderItem {
  id             String   @id @default(cuid())
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId        String
  menuItem       MenuItem @relation(fields: [menuItemId], references: [id])
  menuItemId     String
  quantity       Int
  isBulkCovered  Boolean  @default(false)  // true = this qty is already covered by a BulkOrder
  unitPrice      Decimal  @db.Decimal(10, 2)
  notes          String?
}

// A standalone bulk pre-order: specific items for a site/date range, not tied to a menu
model BulkOrder {
  id           String        @id @default(cuid())
  site         Site?         @relation(fields: [siteId], references: [id])
  siteId       String?       // null = applies to ALL sites
  name         String        // e.g. "Week of June 10 — OJ + Cereal Pre-ship"
  deliveryDate DateTime
  status       OrderStatus   @default(PENDING)
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  items        BulkOrderItem[]
}

model BulkOrderItem {
  id           String    @id @default(cuid())
  bulkOrder    BulkOrder @relation(fields: [bulkOrderId], references: [id], onDelete: Cascade)
  bulkOrderId  String
  menuItem     MenuItem  @relation(fields: [menuItemId], references: [id])
  menuItemId   String
  quantity     Int
  unitPrice    Decimal   @db.Decimal(10, 2) @default(0)
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  IN_TRANSIT
  DELIVERED
  CANCELLED
}
